<%- include('./_nav', { spec: spec, activePage: 'index' }) %>

  <!-- Page content -->
  <div class="max-w-4xl mx-auto px-6 py-8 space-y-10 pb-16">

    <%
      var statusVariant = {
        ACTIVE:     'bg-success-subtle text-success-fg',
        DRAFT:      'bg-warning-subtle text-warning-fg',
        DEPRECATED: 'bg-error-subtle text-error-fg',
        SUNSET:     'bg-surface-overlay text-text-secondary',
      };
      var statusCls = statusVariant[spec.status] || 'bg-surface-overlay text-text-secondary';

      var secSchemes = (spec.components && spec.components.securitySchemes)
        ? Object.entries(spec.components.securitySchemes)
        : [];
    %>

    <!-- ── API info header ── -->
    <header class="space-y-5 pt-2">

      <!-- Title + status badge + metadata line -->
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <h1 class="text-2xl font-bold text-text-primary"><%= spec.info.title %></h1>
          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= statusCls %>">
            <%= spec.status %>
          </span>
        </div>
        <div class="flex items-center gap-2 text-xs font-mono text-text-disabled">
          <span>OpenAPI <%= spec.openapi %></span>
          <span aria-hidden="true">·</span>
          <span>v<%= spec.info.version %></span>
          <% if (spec.info.summary) { %>
            <span aria-hidden="true">·</span>
            <span class="font-sans text-text-secondary"><%= spec.info.summary %></span>
          <% } %>
        </div>
      </div>

      <!-- Description -->
      <% if (spec.info.description) { %>
        <p class="text-sm text-text-secondary leading-relaxed max-w-3xl"><%= spec.info.description %></p>
      <% } %>

      <!-- Contact / license / terms row -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-text-secondary">
        <% if (spec.info.contact && spec.info.contact.email) { %>
          <a href="mailto:<%= spec.info.contact.email %>"
             class="flex items-center gap-1.5 hover:text-primary transition-colors">
            <i class="fa-solid fa-envelope text-[10px]" aria-hidden="true"></i>
            <%= spec.info.contact.name || spec.info.contact.email %>
          </a>
        <% } %>
        <% if (spec.info.license) { %>
          <% if (spec.info.license.url) { %>
            <a href="<%= spec.info.license.url %>" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-1.5 hover:text-primary transition-colors">
              <i class="fa-solid fa-file-contract text-[10px]" aria-hidden="true"></i>
              <%= spec.info.license.name %>
              <i class="fa-solid fa-arrow-up-right-from-square text-[9px]" aria-hidden="true"></i>
            </a>
          <% } else { %>
            <span class="flex items-center gap-1.5">
              <i class="fa-solid fa-file-contract text-[10px]" aria-hidden="true"></i>
              <%= spec.info.license.name %>
            </span>
          <% } %>
        <% } %>
        <% if (spec.info.termsOfService) { %>
          <a href="<%= spec.info.termsOfService %>" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-1.5 hover:text-primary transition-colors">
            Terms of Service
            <i class="fa-solid fa-arrow-up-right-from-square text-[9px]" aria-hidden="true"></i>
          </a>
        <% } %>
      </div>

      <!-- Security schemes card -->
      <% if (secSchemes.length > 0) { %>
      <div class="rounded-xl border border-border bg-surface-raised px-4 py-3 space-y-2">
        <div class="flex items-center gap-2">
          <i class="fa-solid fa-shield text-text-disabled text-xs" aria-hidden="true"></i>
          <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Security schemes</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <% secSchemes.forEach(function(entry) {
            var schemeName = entry[0];
            var scheme     = entry[1];
          %>
            <div class="flex items-start gap-2">
              <%- include('../../../modules/domain/api-doc/SecuritySchemeBadge', { type: scheme.type, name: schemeName }) %>
              <% if (scheme.description) { %>
                <span class="text-xs text-text-secondary leading-5"><%= scheme.description %></span>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Common responses card -->
      <div class="rounded-xl border border-border bg-surface-raised px-4 py-3 space-y-2">
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Common responses</p>
        <div class="flex flex-wrap gap-2">
          <% [['200','OK'],['201','Created'],['204','No Content'],['400','Bad Request'],['401','Unauthorized'],['403','Forbidden'],['404','Not Found'],['422','Unprocessable Entity'],['429','Too Many Requests']].forEach(function(pair) {
            var n = parseInt(pair[0], 10);
            var cls;
            if      (n >= 200 && n < 300) cls = 'bg-success-subtle text-success-fg border-success/30';
            else if (n >= 300 && n < 400) cls = 'bg-info-subtle text-info-fg border-info/30';
            else if (n >= 400 && n < 500) cls = 'bg-warning-subtle text-warning-fg border-warning/30';
            else                          cls = 'bg-error-subtle text-error-fg border-error/30';
          %>
            <span class="inline-flex items-center gap-1.5 rounded border font-mono font-semibold text-xs px-2 py-0.5 <%= cls %>">
              <%= pair[0] %>
              <span class="font-sans font-normal opacity-75 text-[10px]"><%= pair[1] %></span>
            </span>
          <% }); %>
        </div>
      </div>

    </header>

    <!-- Divider -->
    <hr class="border-border">

    <!-- ── Tag sections ── -->
    <%
      var tagPathsMap = {};
      spec.tags.forEach(function(tag) { tagPathsMap[tag.name] = []; });

      spec.paths.forEach(function(pathItem) {
        var ops = pathItem.operations || [];
        ops.forEach(function(op) {
          var opTags = op.tags && op.tags.length ? op.tags : ['Default'];
          opTags.forEach(function(tagName) {
            if (!tagPathsMap[tagName]) tagPathsMap[tagName] = [];
            var already = tagPathsMap[tagName].find(function(p) {
              return p.pathItem.pathItemId === pathItem.pathItemId;
            });
            if (!already) tagPathsMap[tagName].push({ pathItem: pathItem });
          });
        });
      });
    %>

    <div class="space-y-8">
      <% spec.tags.forEach(function(tag) {
        var tagPaths = tagPathsMap[tag.name] || [];
      %>
      <section id="tag-<%= tag.name %>" class="scroll-mt-20">
        <%- include('../../../modules/domain/api-doc/ApiTagSection', {
          tag:         tag,
          paths:       tagPaths,
          defaultOpen: true,
        }) %>
      </section>
      <% }); %>
    </div>

    <!-- Footer -->
    <footer class="pt-6 border-t border-border flex flex-wrap items-center justify-between gap-4 text-xs text-text-disabled">
      <span><%= spec.info.title %> · v<%= spec.info.version %> · OpenAPI <%= spec.openapi %></span>
      <% if (spec.info.contact && spec.info.contact.email) { %>
        <a href="mailto:<%= spec.info.contact.email %>" class="hover:text-text-primary transition-colors">
          <%= spec.info.contact.email %>
        </a>
      <% } %>
    </footer>

  </div><!-- /max-w-4xl -->

    </main>
  </div><!-- /main column -->
</div><!-- /flex h-screen -->
