<%
  var state  = locals.state || {};
  var nat    = state.nat    || {};
  var rules  = nat.portForwardRules  || [];
  var ptRules = nat.portTriggerRules || [];
  var dmz    = nat.dmz  || {};
  var upnp   = nat.upnp || {};

  var inp = 'w-full rounded-lg border border-border bg-surface-base px-3 py-2 text-sm text-text-primary focus:border-border-focus focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors';
  var sel = 'w-full rounded-lg border border-border bg-surface-base px-3 py-2 text-sm text-text-primary focus:border-border-focus focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors';

  var activeRules = rules.filter(function(r){ return r.enabled; }).length;

  var devices = state.connectedDevices || [];
%>

<%- include('./_nav', { activePage: 'nat', state: state }) %>

  <div class="space-y-6">

    <!-- Summary cards -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="rounded-xl border border-border bg-surface-raised p-3 text-center">
        <p class="text-xs text-text-secondary">Active Rules</p>
        <p class="text-2xl font-bold text-text-primary mt-1"><%= activeRules %></p>
        <p class="text-xs text-text-secondary mt-0.5">of <%= rules.length %> total</p>
      </div>
      <div class="rounded-xl border border-border bg-surface-raised p-3 text-center">
        <p class="text-xs text-text-secondary">UPnP</p>
        <p class="text-sm font-semibold mt-2 <%= upnp.enabled ? 'text-success' : 'text-text-secondary' %>">
          <%= upnp.enabled ? 'Enabled' : 'Disabled' %>
        </p>
      </div>
      <div class="rounded-xl border border-border bg-surface-raised p-3 text-center">
        <p class="text-xs text-text-secondary">DMZ</p>
        <p class="text-sm font-semibold mt-2 <%= dmz.enabled ? 'text-warning' : 'text-text-secondary' %>">
          <%= dmz.enabled ? 'Active' : 'Off' %>
        </p>
      </div>
      <div class="rounded-xl border border-border bg-surface-raised p-3 text-center">
        <p class="text-xs text-text-secondary">Hairpin NAT</p>
        <p class="text-sm font-semibold mt-2 <%= nat.hairpinNat ? 'text-success' : 'text-text-secondary' %>">
          <%= nat.hairpinNat ? 'On' : 'Off' %>
        </p>
      </div>
    </div>

    <!-- Port Forwarding Rules -->
    <section class="space-y-3" aria-labelledby="pf-heading">
      <div class="flex items-center justify-between">
        <h2 id="pf-heading" class="text-sm font-semibold text-text-primary">Port Forwarding Rules</h2>
        <span class="text-xs text-text-secondary"><%= activeRules %> active · <%= rules.length %> total</span>
      </div>

      <!-- Add rule form -->
      <div class="rounded-xl border border-dashed border-border bg-surface-base p-4 space-y-3">
        <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide">Add Port Forwarding Rule</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Rule Name</label>
            <input type="text" placeholder="e.g. Plex Media Server" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Protocol</label>
            <select class="<%= sel %>">
              <option value="TCP">TCP</option>
              <option value="UDP">UDP</option>
              <option value="TCP_UDP">TCP + UDP</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">External Port</label>
            <input type="text" placeholder="e.g. 32400 or 8000-8010" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Internal IP Address</label>
            <select class="<%= sel %>">
              <option value="">— Select device or enter manually —</option>
              <% devices.filter(function(d){ return !d.isBlocked; }).forEach(function(dev) { %>
              <option value="<%= dev.ip %>">
                <%= (dev.customName || dev.hostname) %> — <%= dev.ip %>
              </option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Internal Port</label>
            <input type="text" placeholder="Same as external if blank" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Remote IP Restriction <span class="font-normal opacity-60">(optional)</span></label>
            <input type="text" placeholder="Any (leave blank)" class="<%= inp %>">
          </div>
        </div>
        <div class="flex justify-end pt-2 border-t border-border">
          <button type="button" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">
            <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i> Add Rule
          </button>
        </div>
      </div>

      <% if (rules.length > 0) { %>
      <div class="rounded-xl border border-border overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-raised border-b border-border">
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Name</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary hidden sm:table-cell">Protocol</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Ext. Port</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary hidden md:table-cell">Internal</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Enabled</th>
              <th class="text-right py-2.5 px-4 text-xs font-medium text-text-secondary">Action</th>
            </tr>
          </thead>
          <tbody>
            <% rules.forEach(function(rule) { %>
            <tr class="border-t border-border hover:bg-surface-raised transition-colors group">
              <td class="py-3 px-4">
                <p class="font-medium text-text-primary"><%= rule.name %></p>
                <% if (rule.remoteIp) { %>
                <p class="text-xs font-mono text-text-secondary mt-0.5">from: <%= rule.remoteIp %></p>
                <% } %>
              </td>
              <td class="py-3 px-4 hidden sm:table-cell">
                <span class="text-xs bg-surface-overlay border border-border rounded px-1.5 py-0.5 font-mono text-text-secondary">
                  <%= rule.protocol %>
                </span>
              </td>
              <td class="py-3 px-4 font-mono text-xs text-text-primary">
                <%
                  var ep = rule.externalPort;
                  var epStr = (typeof ep === 'object' && ep.start !== undefined) ? ep.start + '–' + ep.end : String(ep);
                %>
                <%= epStr %>
              </td>
              <td class="py-3 px-4 hidden md:table-cell text-xs font-mono text-text-secondary">
                <%
                  var ip2 = rule.internalPort;
                  var ip2Str = (typeof ip2 === 'object' && ip2.start !== undefined) ? ip2.start + '–' + ip2.end : String(ip2);
                %>
                <%= rule.internalIp %>:<%= ip2Str %>
              </td>
              <td class="py-3 px-4">
                <button type="button" role="switch" aria-checked="<%= rule.enabled ? 'true' : 'false' %>"
                  class="relative inline-flex h-5 w-9 flex-shrink-0 items-center rounded-full transition-colors
                    <%= rule.enabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
                  <span class="inline-block h-3 w-3 rounded-full bg-white shadow transition-transform <%= rule.enabled ? 'translate-x-5' : 'translate-x-1' %>"></span>
                </button>
              </td>
              <td class="py-3 px-4 text-right">
                <button type="button" class="text-xs text-error opacity-0 group-hover:opacity-100 hover:underline transition-opacity">Delete</button>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </section>

    <!-- DMZ + UPnP -->
    <div class="grid md:grid-cols-2 gap-4">

      <section class="rounded-xl border border-border bg-surface-raised p-5 space-y-4" aria-labelledby="dmz-heading">
        <div class="flex items-center justify-between">
          <div>
            <h2 id="dmz-heading" class="text-sm font-semibold text-text-primary">DMZ</h2>
            <p class="text-xs text-text-secondary mt-0.5">Expose a host to all inbound traffic</p>
          </div>
          <button type="button" role="switch" aria-checked="<%= dmz.enabled ? 'true' : 'false' %>"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30
              <%= dmz.enabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= dmz.enabled ? 'translate-x-6' : 'translate-x-1' %>"></span>
          </button>
        </div>
        <div class="pt-2 border-t border-border space-y-3">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Target IP Address</label>
            <select class="<%= sel %>">
              <option value="">— Select device —</option>
              <% devices.filter(function(d){ return !d.isBlocked; }).forEach(function(dev) { %>
              <option value="<%= dev.ip %>" <%= dmz.enabled && dmz.targetIp === dev.ip ? 'selected' : '' %>>
                <%= (dev.customName || dev.hostname) %> — <%= dev.ip %>
              </option>
              <% }); %>
            </select>
          </div>
          <% if (dmz.enabled) { %>
          <div class="flex items-start gap-2 rounded-lg border border-warning/30 bg-warning/5 px-3 py-2">
            <i class="fa-solid fa-triangle-exclamation text-warning text-xs mt-0.5 shrink-0" aria-hidden="true"></i>
            <p class="text-xs text-text-secondary">DMZ exposes the target to the internet. Ensure the host has its own firewall.</p>
          </div>
          <% } %>
          <div class="flex justify-end">
            <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
          </div>
        </div>
      </section>

      <section class="rounded-xl border border-border bg-surface-raised p-5 space-y-4" aria-labelledby="upnp-heading">
        <div class="flex items-center justify-between">
          <div>
            <h2 id="upnp-heading" class="text-sm font-semibold text-text-primary">UPnP / NAT-PMP</h2>
            <p class="text-xs text-text-secondary mt-0.5">Automatic port mapping for applications</p>
          </div>
          <button type="button" role="switch" aria-checked="<%= upnp.enabled ? 'true' : 'false' %>"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30
              <%= upnp.enabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= upnp.enabled ? 'translate-x-6' : 'translate-x-1' %>"></span>
          </button>
        </div>
        <% if (upnp.enabled) { %>
        <div class="pt-2 border-t border-border space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-text-secondary mb-1.5">Advertise Period (s)</label>
              <input type="number" value="<%= upnp.advertisePeriod %>" min="60" max="3600" class="<%= inp %>">
            </div>
            <div>
              <label class="block text-xs font-medium text-text-secondary mb-1.5">TTL (hops)</label>
              <input type="number" value="<%= upnp.ttl %>" min="1" max="10" class="<%= inp %>">
            </div>
          </div>
          <div class="flex justify-end pt-2 border-t border-border">
            <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
          </div>
        </div>
        <% } else { %>
        <p class="text-xs text-text-secondary pt-2 border-t border-border">
          UPnP is disabled. Applications cannot automatically open ports. Use manual port forwarding above.
        </p>
        <% } %>
      </section>

    </div>

    <!-- Hairpin NAT -->
    <section class="rounded-xl border border-border bg-surface-raised" aria-labelledby="hairpin-heading">
      <div class="flex items-center justify-between p-4">
        <div>
          <h2 id="hairpin-heading" class="text-sm font-semibold text-text-primary">Hairpin NAT (NAT Loopback)</h2>
          <p class="text-xs text-text-secondary mt-0.5">
            Allows LAN clients to reach port-forwarded services using the public WAN IP address.
          </p>
        </div>
        <button type="button" role="switch" aria-checked="<%= nat.hairpinNat ? 'true' : 'false' %>"
          class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30 ml-4
            <%= nat.hairpinNat ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
          <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= nat.hairpinNat ? 'translate-x-6' : 'translate-x-1' %>"></span>
        </button>
      </div>
    </section>

  </div>

<%- include('./_nav-close') %>
