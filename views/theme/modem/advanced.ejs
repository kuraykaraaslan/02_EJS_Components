<%
  var state   = locals.state || {};
  var nat     = state.nat    || {};
  var vpn     = state.vpn    || [];
  var pfRules = nat.portForwardRules || [];
  var dmz     = nat.dmz      || {};
  var upnp    = nat.upnp     || {};
%>

<%- include('./_nav', { activePage: 'advanced', state: state }) %>

  <div class="space-y-6">

    <!-- Port Forwarding -->
    <section class="space-y-3" aria-labelledby="pf-heading">
      <h2 id="pf-heading" class="text-sm font-semibold text-text-primary">Port Forwarding (<%= pfRules.length %>)</h2>
      <% if (pfRules.length === 0) { %>
      <p class="text-sm text-text-secondary py-4">No port forwarding rules.</p>
      <% } else { %>
      <div class="rounded-xl border border-border overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-raised border-b border-border">
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Name</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary hidden sm:table-cell">Protocol</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Ext Port</th>
              <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary hidden md:table-cell">Internal</th>
            </tr>
          </thead>
          <tbody>
            <% pfRules.forEach(function(rule) { %>
            <%- include('../../../modules/domain/modem/PortForwardRow', { rule: rule }) %>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </section>

    <!-- DMZ + UPnP -->
    <div class="grid md:grid-cols-2 gap-4">
      <section class="rounded-xl border border-border bg-surface-raised p-5 space-y-3" aria-labelledby="dmz-heading">
        <div class="flex items-center justify-between">
          <h2 id="dmz-heading" class="text-sm font-semibold text-text-primary">DMZ</h2>
          <span class="text-xs font-medium <%= dmz.enabled ? 'text-error' : 'text-text-secondary' %>">
            <%= dmz.enabled ? 'Active' : 'Off' %>
          </span>
        </div>
        <p class="text-xs text-text-secondary">
          Target: <span class="font-mono text-text-primary"><%= dmz.enabled && dmz.targetIp ? dmz.targetIp : '—' %></span>
        </p>
      </section>

      <section class="rounded-xl border border-border bg-surface-raised p-5 space-y-3" aria-labelledby="upnp-heading">
        <div class="flex items-center justify-between">
          <h2 id="upnp-heading" class="text-sm font-semibold text-text-primary">UPnP</h2>
          <span class="text-xs font-medium <%= upnp.enabled ? 'text-success' : 'text-text-secondary' %>">
            <%= upnp.enabled ? 'Enabled' : 'Disabled' %>
          </span>
        </div>
        <dl class="grid grid-cols-2 gap-2 text-xs">
          <div>
            <dt class="text-text-secondary">Advertise Period</dt>
            <dd class="font-medium text-text-primary mt-0.5"><%= upnp.advertisePeriod %>s</dd>
          </div>
          <div>
            <dt class="text-text-secondary">TTL</dt>
            <dd class="font-medium text-text-primary mt-0.5"><%= upnp.ttl %></dd>
          </div>
        </dl>
      </section>
    </div>

    <!-- Hairpin NAT -->
    <div class="flex items-center gap-3 rounded-xl border border-border bg-surface-raised p-4">
      <i class="fa-solid fa-rotate text-primary text-sm" aria-hidden="true"></i>
      <div class="flex-1">
        <p class="text-sm font-medium text-text-primary">Hairpin NAT (NAT Loopback)</p>
        <p class="text-xs text-text-secondary mt-0.5">Allows LAN clients to reach internal servers via WAN IP.</p>
      </div>
      <span class="text-xs font-semibold <%= nat.hairpinNat ? 'text-success' : 'text-text-secondary' %>">
        <%= nat.hairpinNat ? 'On' : 'Off' %>
      </span>
    </div>

    <!-- VPN -->
    <section class="space-y-3" aria-labelledby="vpn-heading">
      <h2 id="vpn-heading" class="text-sm font-semibold text-text-primary">VPN (<%= vpn.length %>)</h2>
      <% if (vpn.length === 0) { %>
      <p class="text-sm text-text-secondary">No VPN instances configured.</p>
      <% } else { %>
      <div class="space-y-3">
        <% vpn.forEach(function(v) { %>
        <div class="rounded-xl border border-border bg-surface-raised p-4 flex items-center gap-4">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl
            <%= v.status === 'ACTIVE' ? 'bg-success/10 text-success' : 'bg-surface-overlay text-text-secondary' %>">
            <i class="fa-solid fa-lock text-sm" aria-hidden="true"></i>
          </span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <p class="text-sm font-semibold text-text-primary"><%= v.name %></p>
              <span class="text-xs bg-surface-overlay border border-border rounded px-1.5 py-0.5 text-text-secondary font-mono"><%= v.type %></span>
              <span class="text-xs bg-surface-overlay border border-border rounded px-1.5 py-0.5 text-text-secondary"><%= v.role %></span>
            </div>
            <p class="text-xs text-text-secondary mt-0.5">
              <% if (v.role === 'SERVER') { %>
              <%= v.clientCount %> client<%= v.clientCount !== 1 ? 's' : '' %> connected
              <% } else if (v.serverAddr) { %>
              Server: <span class="font-mono text-text-primary"><%= v.serverAddr %></span>
              <% } %>
            </p>
          </div>
          <span class="inline-flex items-center gap-1.5 rounded-full border text-xs px-2.5 py-1 font-medium
            <%= v.status === 'ACTIVE'   ? 'bg-success/10 border-success/30 text-success'
              : v.status === 'ERROR'    ? 'bg-error/10 border-error/30 text-error'
              : 'bg-surface-overlay border-border text-text-secondary' %>">
            <span class="h-1.5 w-1.5 rounded-full flex-shrink-0
              <%= v.status === 'ACTIVE' ? 'bg-success' : v.status === 'ERROR' ? 'bg-error' : 'bg-text-secondary' %>"></span>
            <%= v.status %>
          </span>
        </div>
        <% }); %>
      </div>
      <% } %>
    </section>

  </div>

<%- include('./_nav-close') %>
