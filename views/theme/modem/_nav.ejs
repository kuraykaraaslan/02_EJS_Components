<%
  var _activePage = locals.activePage || '';
  var _state      = locals.state      || {};
  var _unread     = (_state.alerts || []).filter(function(a) { return !a.read; }).length;

  var nav = [
    { id: 'dashboard', label: 'Dashboard',         href: '/theme/modem',           icon: 'fa-solid fa-gauge'          },
    { id: 'network',   label: 'Network',            href: '/theme/modem/network',   icon: 'fa-solid fa-network-wired'  },
    { id: 'wifi',      label: 'Wi-Fi',              href: '/theme/modem/wifi',      icon: 'fa-solid fa-wifi'           },
    { id: 'devices',   label: 'Devices',            href: '/theme/modem/devices',   icon: 'fa-solid fa-display'        },
    { id: 'firewall',  label: 'Firewall',           href: '/theme/modem/firewall',  icon: 'fa-solid fa-shield-halved'  },
    { id: 'nat',       label: 'NAT',                href: '/theme/modem/nat',       icon: 'fa-solid fa-right-left'     },
    { id: 'vpn',       label: 'VPN',                href: '/theme/modem/vpn',       icon: 'fa-solid fa-lock'           },
    { id: 'qos',       label: 'QoS',                href: '/theme/modem/qos',       icon: 'fa-solid fa-sliders'        },
    { id: 'parental',  label: 'Parental Controls',  href: '/theme/modem/parental',  icon: 'fa-solid fa-shield-child'   },
    { id: 'system',    label: 'System',             href: '/theme/modem/system',    icon: 'fa-solid fa-microchip'      },
    { id: 'settings',  label: 'Settings',           href: '/theme/modem/settings',  icon: 'fa-solid fa-gear'           },
  ];

  var sysModel  = (_state.system && _state.system.model)   ? _state.system.model.model   : 'Router';
  var sysHost   = (_state.system && _state.system.hostname) ? _state.system.hostname      : '';
  var wanStatus = (_state.wan   && _state.wan.status)       ? _state.wan.status           : 'DISCONNECTED';
  var wanIp     = (_state.wan   && _state.wan.ipAddress)    ? _state.wan.ipAddress        : '—';

  var activeNav = nav.find(function(n) { return n.id === _activePage; });
%>

<div class="flex h-screen overflow-hidden bg-surface-base">

  <!-- Sidebar -->
  <aside class="hidden md:flex w-56 shrink-0 flex-col border-r border-border bg-surface-raised">

    <div class="flex h-14 items-center gap-3 border-b border-border px-4">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-primary-fg text-sm">
        <i class="fa-solid fa-router" aria-hidden="true"></i>
      </span>
      <div class="min-w-0">
        <p class="text-xs font-bold text-text-primary leading-none"><%= sysModel %></p>
        <p class="text-xs text-text-secondary mt-0.5 truncate"><%= sysHost %></p>
      </div>
    </div>

    <nav class="flex-1 overflow-y-auto py-3 px-2" aria-label="Router admin navigation">
      <ul class="space-y-0.5" role="list">
        <% nav.forEach(function(item) {
          var isActive = item.id === _activePage;
        %>
        <li role="listitem">
          <a href="<%= item.href %>"
            class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors
              <%= isActive ? 'bg-primary-subtle text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>"
            <%= isActive ? 'aria-current="page"' : '' %>>
            <i class="<%= item.icon %> w-4 shrink-0 text-xs" aria-hidden="true"></i>
            <span class="truncate"><%= item.label %></span>
            <% if (item.id === 'dashboard' && _unread > 0) { %>
            <span class="ml-auto flex h-4 min-w-4 items-center justify-center rounded-full bg-error text-primary-fg text-xs font-bold leading-none px-1"
                  aria-label="<%= _unread %> unread alerts">
              <%= _unread %>
            </span>
            <% } %>
          </a>
        </li>
        <% }); %>
      </ul>
    </nav>

    <div class="border-t border-border px-4 py-3">
      <div class="flex items-center gap-2 text-xs">
        <span class="h-2 w-2 rounded-full flex-shrink-0
          <%= wanStatus === 'CONNECTED' ? 'bg-success' : wanStatus === 'CONNECTING' ? 'bg-warning animate-pulse' : 'bg-error' %>"
          aria-hidden="true"></span>
        <span class="font-mono text-text-primary truncate"><%= wanIp %></span>
      </div>
    </div>

  </aside>

  <!-- Main column -->
  <div class="flex-1 flex flex-col min-w-0">

    <header class="flex h-14 items-center justify-between border-b border-border px-6 bg-surface-raised">
      <div class="min-w-0">
        <a href="/theme/modem" class="text-xs text-text-secondary hover:text-text-primary transition-colors">
          <i class="fa-solid fa-arrow-left text-xs mr-1" aria-hidden="true"></i>Modem Theme
        </a>
        <h1 class="text-base font-bold text-text-primary mt-0.5 leading-none">
          <%= activeNav ? activeNav.label : 'Dashboard' %>
        </h1>
      </div>
      <% if (_unread > 0) { %>
      <a href="/theme/modem"
         class="flex items-center gap-2 rounded-lg bg-error/10 border border-error/20 px-3 py-1.5 text-xs font-medium text-error hover:bg-error/20 transition-colors">
        <i class="fa-solid fa-bell" aria-hidden="true"></i>
        <%= _unread %> alert<%= _unread > 1 ? 's' : '' %>
      </a>
      <% } %>
    </header>

    <main class="flex-1 overflow-y-auto p-6">
