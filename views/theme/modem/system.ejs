<%
  var state     = locals.state        || {};
  var system    = state.system        || {};
  var firmware  = system.firmware     || {};
  var resources = system.resources    || {};
  var sysTime   = system.time         || {};
  var logs      = state.logs          || [];
  var led       = state.led           || {};
  var notifCfg  = state.notifications || {};
  var usb       = state.usb           || {};
  var usbDevices = usb.devices        || [];
  var usbFolders = usb.sharedFolders  || [];
  var logFilter = locals.logFilter    || 'ALL';

  var inp = 'w-full rounded-lg border border-border bg-surface-base px-3 py-2 text-sm text-text-primary focus:border-border-focus focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors';
  var sel = 'w-full rounded-lg border border-border bg-surface-base px-3 py-2 text-sm text-text-primary focus:border-border-focus focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors';

  var filteredLogs = logFilter === 'ALL'
    ? logs
    : logs.filter(function(l) { return l.source === logFilter || l.level === logFilter; });

  var levelColor = { DEBUG: 'text-text-secondary', INFO: 'text-info', WARNING: 'text-warning', ERROR: 'text-error', CRITICAL: 'text-error' };

  function fmtTime(iso) {
    if (!iso) return '';
    try {
      var d = new Date(iso);
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) + ' ' +
             d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    } catch(e) { return iso; }
  }

  function fmtBytes(b) {
    if (!b) return '0 B';
    if (b >= 1099511627776) return (b / 1099511627776).toFixed(1) + ' TB';
    if (b >= 1073741824)    return (b / 1073741824).toFixed(1)    + ' GB';
    if (b >= 1048576)       return (b / 1048576).toFixed(0)       + ' MB';
    return (b / 1024).toFixed(0) + ' KB';
  }
%>

<%- include('./_nav', { activePage: 'system', state: state }) %>

  <div class="space-y-6">

    <!-- System Status Card -->
    <%- include('../../../modules/domain/modem/SystemStatusCard', {
      hostname:  system.hostname,
      model:     system.model,
      firmware:  firmware,
      resources: resources,
      time:      sysTime,
    }) %>

    <!-- Firmware -->
    <section class="space-y-3" aria-labelledby="firmware-heading">
      <h2 id="firmware-heading" class="text-sm font-semibold text-text-primary">Firmware</h2>

      <% if (firmware.updateAvailable) { %>
      <div class="flex items-center gap-4 rounded-xl border border-warning/30 bg-warning/5 p-4">
        <i class="fa-solid fa-circle-arrow-up text-warning text-xl shrink-0" aria-hidden="true"></i>
        <div class="flex-1">
          <p class="text-sm font-semibold text-text-primary">Update available — v<%= firmware.latestVersion %></p>
          <p class="text-xs text-text-secondary mt-0.5">Built <%= firmware.buildDate %> · Current: v<%= firmware.currentVersion %></p>
        </div>
        <button type="button"
          class="shrink-0 inline-flex items-center gap-2 rounded-lg bg-warning text-white text-xs font-semibold px-3 py-1.5 hover:bg-warning/90 transition-colors">
          <i class="fa-solid fa-arrow-up-from-bracket" aria-hidden="true"></i> Update Now
        </button>
      </div>
      <% } %>

      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="grid sm:grid-cols-3 gap-4 text-xs">
          <div>
            <dt class="text-text-secondary">Current Version</dt>
            <dd class="font-mono font-medium text-text-primary mt-0.5"><%= firmware.currentVersion %></dd>
          </div>
          <div>
            <dt class="text-text-secondary">Build Date</dt>
            <dd class="font-medium text-text-primary mt-0.5"><%= firmware.buildDate %></dd>
          </div>
          <div>
            <dt class="text-text-secondary">Auto-Update</dt>
            <dd class="mt-0.5">
              <button type="button" role="switch" aria-checked="<%= firmware.autoUpdateEnabled ? 'true' : 'false' %>"
                class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors
                  <%= firmware.autoUpdateEnabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
                <span class="inline-block h-3 w-3 rounded-full bg-white shadow transition-transform <%= firmware.autoUpdateEnabled ? 'translate-x-5' : 'translate-x-1' %>"></span>
              </button>
            </dd>
          </div>
        </div>
        <div class="pt-3 border-t border-border space-y-2">
          <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide">Manual Firmware Upload</p>
          <div class="flex items-center gap-3">
            <label class="flex-1 flex items-center gap-3 rounded-lg border border-border bg-surface-base px-3 py-2 cursor-pointer hover:border-primary transition-colors">
              <i class="fa-solid fa-file-arrow-up text-text-secondary" aria-hidden="true"></i>
              <span class="text-sm text-text-secondary">Choose firmware file (.trx / .bin)</span>
              <input type="file" accept=".trx,.bin,.img" class="sr-only">
            </label>
            <button type="button" class="shrink-0 rounded-lg bg-surface-overlay border border-border text-text-secondary text-sm px-4 py-2 hover:bg-surface-sunken transition-colors">Upload</button>
          </div>
          <p class="text-xs text-warning flex items-center gap-1.5">
            <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
            Do not power off the router during firmware update.
          </p>
        </div>
      </div>
    </section>

    <!-- Device Identity -->
    <section class="space-y-3" aria-labelledby="identity-heading">
      <h2 id="identity-heading" class="text-sm font-semibold text-text-primary">Device Identity</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Router Hostname</label>
            <input type="text" value="<%= system.hostname || '' %>" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Location / Description</label>
            <input type="text" placeholder="e.g. Living Room" class="<%= inp %>">
          </div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 pt-3 border-t border-border text-xs">
          <% [
            { label: 'Model',     value: (system.model || {}).model       },
            { label: 'Hardware',  value: (system.model || {}).hardware    },
            { label: 'Serial',    value: (system.model || {}).serial      },
            { label: 'WAN MAC',   value: system.wanMac                   },
          ].forEach(function(f) { %>
          <div>
            <dt class="text-text-secondary"><%= f.label %></dt>
            <dd class="font-mono font-medium text-text-primary mt-0.5"><%= f.value || '—' %></dd>
          </div>
          <% }); %>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

    <!-- Admin Account -->
    <section class="space-y-3" aria-labelledby="admin-heading">
      <h2 id="admin-heading" class="text-sm font-semibold text-text-primary">Administrator Account</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Username</label>
            <input type="text" value="admin" class="<%= inp %>">
          </div>
          <div><!-- spacer --></div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Current Password</label>
            <input type="password" placeholder="••••••••" class="<%= inp %>">
          </div>
          <div><!-- spacer --></div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">New Password</label>
            <input type="password" placeholder="Min. 8 characters" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Confirm New Password</label>
            <input type="password" placeholder="Repeat new password" class="<%= inp %>">
          </div>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Change Password</button>
        </div>
      </div>
    </section>

    <!-- Date & Time -->
    <section class="space-y-3" aria-labelledby="datetime-heading">
      <h2 id="datetime-heading" class="text-sm font-semibold text-text-primary">Date &amp; Time</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-text-primary">Automatic Time (NTP)</p>
            <p class="text-xs text-text-secondary mt-0.5">Sync clock from internet time servers</p>
          </div>
          <button type="button" role="switch" aria-checked="<%= sysTime.ntpEnabled ? 'true' : 'false' %>"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30
              <%= sysTime.ntpEnabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= sysTime.ntpEnabled ? 'translate-x-6' : 'translate-x-1' %>"></span>
          </button>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 pt-3 border-t border-border">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">NTP Server</label>
            <input type="text" value="<%= sysTime.ntpServer || 'pool.ntp.org' %>" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Timezone</label>
            <select class="<%= sel %>">
              <% var tzOptions = ['Europe/Istanbul', 'Europe/London', 'Europe/Berlin', 'America/New_York', 'America/Los_Angeles', 'Asia/Tokyo', 'UTC'];
                 tzOptions.forEach(function(tz) { %>
              <option value="<%= tz %>" <%= sysTime.timezone === tz ? 'selected' : '' %>><%= tz %></option>
              <% }); %>
            </select>
          </div>
          <% if (!sysTime.ntpEnabled) { %>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Date</label>
            <input type="date" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Time</label>
            <input type="time" class="<%= inp %>">
          </div>
          <% } %>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

    <!-- LED + Notifications -->
    <div class="grid md:grid-cols-2 gap-4">

      <section class="rounded-xl border border-border bg-surface-raised p-5 space-y-4" aria-labelledby="led-heading">
        <h2 id="led-heading" class="text-sm font-semibold text-text-primary">LED Indicator</h2>
        <div>
          <label class="block text-xs font-medium text-text-secondary mb-2">Mode</label>
          <div class="flex gap-2">
            <% ['ON','OFF','SCHEDULED'].forEach(function(m) { %>
            <button type="button"
              class="rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors
                <%= led.mode === m
                  ? 'bg-primary text-primary-fg border-primary'
                  : 'border-border text-text-secondary hover:bg-surface-overlay' %>">
              <%= m %>
            </button>
            <% }); %>
          </div>
        </div>
        <% if (led.mode === 'SCHEDULED' && led.schedule) { %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">On Time</label>
            <input type="time" value="<%= led.schedule.startTime %>" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Off Time</label>
            <input type="time" value="<%= led.schedule.endTime %>" class="<%= inp %>">
          </div>
        </div>
        <% } %>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-text-primary">Night Mode</p>
            <p class="text-xs text-text-secondary mt-0.5">Dim LED after sunset</p>
          </div>
          <button type="button" role="switch" aria-checked="<%= led.nightMode ? 'true' : 'false' %>"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors
              <%= led.nightMode ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= led.nightMode ? 'translate-x-6' : 'translate-x-1' %>"></span>
          </button>
        </div>
        <div class="flex justify-end pt-2 border-t border-border">
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </section>

      <section class="rounded-xl border border-border bg-surface-raised p-5 space-y-4" aria-labelledby="notif-heading">
        <h2 id="notif-heading" class="text-sm font-semibold text-text-primary">Notifications</h2>
        <div>
          <label class="block text-xs font-medium text-text-secondary mb-1.5">Alert Email</label>
          <input type="email" value="<%= notifCfg.email || '' %>" placeholder="admin@example.com" class="<%= inp %>">
        </div>
        <div>
          <label class="block text-xs font-medium text-text-secondary mb-1.5">Syslog Server</label>
          <input type="text" value="<%= notifCfg.syslogServer || '' %>" placeholder="192.168.1.x:514" class="<%= inp %>">
        </div>
        <div class="space-y-1.5">
          <p class="text-xs font-medium text-text-secondary">Notify on events:</p>
          <% var allAlerts = ['FIRMWARE_AVAILABLE','WAN_DISCONNECTED','WAN_RECONNECTED','DEVICE_JOINED','INTRUSION_DETECTED','HIGH_CPU','HIGH_TEMPERATURE','USB_MOUNTED'];
             allAlerts.forEach(function(t) { %>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" <%= (notifCfg.enabled || []).indexOf(t) !== -1 ? 'checked' : '' %> class="rounded border-border text-primary">
            <span class="text-xs text-text-primary"><%= t.replace(/_/g,' ') %></span>
          </label>
          <% }); %>
        </div>
        <div class="flex justify-end pt-2 border-t border-border">
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </section>
    </div>

    <!-- USB Storage -->
    <% if (usbDevices.length > 0) { %>
    <section class="space-y-3" aria-labelledby="usb-heading">
      <h2 id="usb-heading" class="text-sm font-semibold text-text-primary">USB Storage</h2>
      <div class="space-y-3">
        <% usbDevices.forEach(function(dev) {
          var usedPct = dev.totalBytes > 0 ? Math.round(dev.usedBytes / dev.totalBytes * 100) : 0;
          var barColor = usedPct >= 90 ? 'bg-error' : usedPct >= 70 ? 'bg-warning' : 'bg-success';
        %>
        <div class="rounded-xl border border-border bg-surface-raised p-4 space-y-3">
          <div class="flex items-center gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-surface-overlay text-text-secondary shrink-0">
              <i class="fa-solid fa-hard-drive text-sm" aria-hidden="true"></i>
            </span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <p class="text-sm font-semibold text-text-primary truncate"><%= dev.label || 'USB Drive' %></p>
                <span class="text-xs font-mono bg-surface-overlay border border-border rounded px-1.5 py-0.5 text-text-secondary"><%= dev.filesystem %></span>
                <% if (!dev.mounted) { %><span class="text-xs text-error font-medium">Unmounted</span><% } %>
              </div>
              <p class="text-xs text-text-secondary mt-0.5"><%= dev.vendor || 'Unknown' %> · <%= fmtBytes(dev.usedBytes) %> / <%= fmtBytes(dev.totalBytes) %></p>
            </div>
            <button type="button" class="text-xs text-error border border-error/30 rounded-lg px-2 py-1 hover:bg-error/5 transition-colors">Eject</button>
          </div>
          <div>
            <div class="flex justify-between text-xs text-text-secondary mb-1"><span>Used</span><span><%= usedPct %>%</span></div>
            <div class="h-1.5 rounded-full bg-surface-sunken overflow-hidden">
              <div class="h-full rounded-full <%= barColor %>" style="width:<%= usedPct %>%"></div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>

      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="flex items-center justify-between rounded-lg border border-border bg-surface-base px-4 py-3">
            <div>
              <p class="text-sm font-medium text-text-primary">Samba (SMB) Share</p>
              <p class="text-xs text-text-secondary mt-0.5">Access storage over Windows network</p>
            </div>
            <button type="button" role="switch" aria-checked="<%= usb.sambaEnabled ? 'true' : 'false' %>"
              class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors
                <%= usb.sambaEnabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
              <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= usb.sambaEnabled ? 'translate-x-6' : 'translate-x-1' %>"></span>
            </button>
          </div>
          <div class="flex items-center justify-between rounded-lg border border-border bg-surface-base px-4 py-3">
            <div>
              <p class="text-sm font-medium text-text-primary">FTP Server</p>
              <p class="text-xs text-text-secondary mt-0.5">Port <%= usb.ftpPort || 21 %></p>
            </div>
            <button type="button" role="switch" aria-checked="<%= usb.ftpEnabled ? 'true' : 'false' %>"
              class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full transition-colors
                <%= usb.ftpEnabled ? 'bg-primary' : 'bg-surface-sunken border border-border' %>">
              <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform <%= usb.ftpEnabled ? 'translate-x-6' : 'translate-x-1' %>"></span>
            </button>
          </div>
        </div>

        <% if (usbFolders.length > 0) { %>
        <div class="rounded-xl border border-border overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-surface-raised border-b border-border">
                <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Folder</th>
                <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary hidden sm:table-cell">Path</th>
                <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">SMB</th>
                <th class="text-left py-2.5 px-4 text-xs font-medium text-text-secondary">Access</th>
                <th class="text-right py-2.5 px-4 text-xs font-medium text-text-secondary">Action</th>
              </tr>
            </thead>
            <tbody>
              <% usbFolders.forEach(function(folder) { %>
              <tr class="border-t border-border hover:bg-surface-raised transition-colors group">
                <td class="py-3 px-4 font-medium text-text-primary">
                  <i class="fa-solid fa-folder text-warning text-xs mr-1.5" aria-hidden="true"></i><%= folder.name %>
                </td>
                <td class="py-3 px-4 font-mono text-xs text-text-secondary hidden sm:table-cell"><%= folder.path %></td>
                <td class="py-3 px-4 text-xs">
                  <span class="<%= folder.samba ? 'text-success font-medium' : 'text-text-secondary' %>"><%= folder.samba ? 'On' : 'Off' %></span>
                </td>
                <td class="py-3 px-4 text-xs font-medium <%= folder.readOnly ? 'text-text-secondary' : 'text-info' %>">
                  <%= folder.readOnly ? 'Read-only' : 'Read/Write' %>
                  <% if (folder.password) { %><i class="fa-solid fa-lock ml-1 text-text-secondary" aria-hidden="true"></i><% } %>
                </td>
                <td class="py-3 px-4 text-right">
                  <button type="button" class="text-xs text-error opacity-0 group-hover:opacity-100 hover:underline transition-opacity">Remove</button>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </section>
    <% } %>

    <!-- Backup & Restore -->
    <section class="space-y-3" aria-labelledby="backup-heading">
      <h2 id="backup-heading" class="text-sm font-semibold text-text-primary">Backup &amp; Restore</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide">Export Configuration</p>
            <p class="text-xs text-text-secondary">Download all current settings as an encrypted backup file.</p>
            <button type="button" class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface-base px-4 py-2 text-sm font-medium text-text-primary hover:bg-surface-overlay transition-colors">
              <i class="fa-solid fa-download" aria-hidden="true"></i> Download Backup
            </button>
          </div>
          <div class="space-y-2">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide">Restore Configuration</p>
            <p class="text-xs text-text-secondary">Upload a previously exported backup file to restore all settings.</p>
            <div class="flex gap-2">
              <label class="flex-1 flex items-center gap-2 rounded-lg border border-border bg-surface-base px-3 py-2 cursor-pointer hover:border-primary transition-colors text-sm text-text-secondary">
                <i class="fa-solid fa-file-arrow-up text-text-secondary" aria-hidden="true"></i>
                Choose backup file
                <input type="file" accept=".cfg,.bak,.conf" class="sr-only">
              </label>
              <button type="button" class="shrink-0 rounded-lg bg-primary text-primary-fg text-sm px-3 py-2 hover:bg-primary-hover transition-colors">Restore</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Reboot & Factory Reset -->
    <section class="space-y-3" aria-labelledby="maintenance-heading">
      <h2 id="maintenance-heading" class="text-sm font-semibold text-text-primary">Maintenance</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-3">
          <div class="flex items-center gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-info/10 text-info shrink-0">
              <i class="fa-solid fa-rotate" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-sm font-semibold text-text-primary">Reboot Router</p>
              <p class="text-xs text-text-secondary mt-0.5">Restart without clearing any settings</p>
            </div>
          </div>
          <button type="button"
            class="w-full rounded-lg border border-info/30 bg-info/5 text-info text-sm font-semibold py-2 hover:bg-info/10 transition-colors">
            Reboot Now
          </button>
        </div>
        <div class="rounded-xl border border-error/30 bg-surface-raised p-5 space-y-3">
          <div class="flex items-center gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-error/10 text-error shrink-0">
              <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
            </span>
            <div>
              <p class="text-sm font-semibold text-text-primary">Factory Reset</p>
              <p class="text-xs text-text-secondary mt-0.5">Erase all settings and return to defaults</p>
            </div>
          </div>
          <div class="space-y-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="rounded border-border text-error">
              <span class="text-xs text-text-secondary">I understand this will erase all configuration</span>
            </label>
            <button type="button"
              class="w-full rounded-lg bg-error text-white text-sm font-semibold py-2 hover:bg-error/90 transition-colors">
              Factory Reset
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- System Log -->
    <section class="space-y-3" aria-labelledby="log-heading">
      <div class="flex items-center justify-between flex-wrap gap-3">
        <h2 id="log-heading" class="text-sm font-semibold text-text-primary">System Log (<%= filteredLogs.length %>)</h2>
        <div class="flex gap-1.5 flex-wrap" role="group" aria-label="Log filter">
          <% ['ALL','INFO','WARNING','ERROR','WAN','WIFI','DHCP','FIREWALL'].forEach(function(f) { %>
          <a href="/theme/modem/system?logFilter=<%= f %>"
            class="text-xs rounded-lg border px-2.5 py-1 font-medium transition-colors
              <%= logFilter === f
                ? 'bg-primary text-primary-fg border-primary'
                : 'border-border text-text-secondary hover:text-text-primary hover:bg-surface-overlay' %>">
            <%= f %>
          </a>
          <% }); %>
        </div>
      </div>

      <div class="rounded-xl border border-border overflow-hidden">
        <table class="w-full text-xs font-mono">
          <thead>
            <tr class="bg-surface-raised border-b border-border">
              <th class="text-left py-2.5 px-4 font-sans text-xs font-medium text-text-secondary">Time</th>
              <th class="text-left py-2.5 px-4 font-sans text-xs font-medium text-text-secondary hidden sm:table-cell">Level</th>
              <th class="text-left py-2.5 px-4 font-sans text-xs font-medium text-text-secondary hidden md:table-cell">Source</th>
              <th class="text-left py-2.5 px-4 font-sans text-xs font-medium text-text-secondary">Message</th>
            </tr>
          </thead>
          <tbody>
            <% if (filteredLogs.length === 0) { %>
            <tr><td colspan="4" class="py-10 text-center font-sans text-sm text-text-secondary">No log entries.</td></tr>
            <% } else {
              filteredLogs.forEach(function(entry) {
                var lc = levelColor[entry.level] || 'text-text-secondary';
            %>
            <tr class="border-t border-border hover:bg-surface-raised transition-colors">
              <td class="py-2.5 px-4 text-text-secondary whitespace-nowrap"><%= fmtTime(entry.timestamp) %></td>
              <td class="py-2.5 px-4 hidden sm:table-cell font-semibold <%= lc %>"><%= entry.level %></td>
              <td class="py-2.5 px-4 hidden md:table-cell text-text-secondary"><%= entry.source %></td>
              <td class="py-2.5 px-4 text-text-primary">
                <%= entry.message %>
                <% if (entry.details) { %><span class="text-text-secondary"> — <%= entry.details %></span><% } %>
              </td>
            </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
      <div class="flex justify-end">
        <button type="button" class="inline-flex items-center gap-2 text-xs text-text-secondary hover:text-error transition-colors">
          <i class="fa-solid fa-trash-can" aria-hidden="true"></i> Clear Log
        </button>
      </div>
    </section>

  </div>

<%- include('./_nav-close') %>
