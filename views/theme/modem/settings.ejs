<%
  var state = locals.state || {};

  var inp = 'w-full rounded-lg border border-border bg-surface-base px-3 py-2 text-sm text-text-primary focus:border-border-focus focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors';
  var sel = 'w-full rounded-lg border border-border bg-surface-base px-3 py-2 text-sm text-text-primary focus:border-border-focus focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors';
%>

<%- include('./_nav', { activePage: 'settings', state: state }) %>

  <div class="space-y-6">

    <!-- Web Interface -->
    <section class="space-y-3" aria-labelledby="webui-heading">
      <h2 id="webui-heading" class="text-sm font-semibold text-text-primary">Web Interface</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">HTTP Port</label>
            <input type="number" value="80" min="1024" max="65535" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">HTTPS Port</label>
            <input type="number" value="443" min="1024" max="65535" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Session Timeout (minutes)</label>
            <input type="number" value="30" min="5" max="480" class="<%= inp %>">
          </div>
        </div>

        <div class="divide-y divide-border rounded-xl border border-border overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3">
            <div>
              <p class="text-sm font-medium text-text-primary">Force HTTPS</p>
              <p class="text-xs text-text-secondary mt-0.5">Redirect all HTTP connections to HTTPS</p>
            </div>
            <button type="button" role="switch" aria-checked="true"
              class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
              <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-6"></span>
            </button>
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <div>
              <p class="text-sm font-medium text-text-primary">HSTS Strict Transport</p>
              <p class="text-xs text-text-secondary mt-0.5">Enable HTTP Strict Transport Security header</p>
            </div>
            <button type="button" role="switch" aria-checked="false"
              class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
              <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
            </button>
          </div>
        </div>

        <div class="space-y-2">
          <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide">TLS Certificate</p>
          <div class="flex items-center justify-between rounded-lg border border-border bg-surface-base px-4 py-3">
            <div>
              <p class="text-sm font-medium text-text-primary">Self-signed Certificate</p>
              <p class="text-xs text-text-secondary font-mono mt-0.5">CN=KONNECT-KT-3535n · Expires: 2027-01-01</p>
            </div>
            <button type="button" class="text-xs text-primary hover:underline font-medium">Renew</button>
          </div>
          <div class="flex gap-2">
            <label class="flex-1 flex items-center gap-2 rounded-lg border border-border bg-surface-base px-3 py-2 cursor-pointer hover:border-primary transition-colors text-sm text-text-secondary">
              <i class="fa-solid fa-certificate text-text-secondary text-xs" aria-hidden="true"></i>
              Upload custom certificate (.pem / .crt + key)
              <input type="file" accept=".pem,.crt,.cert" class="sr-only">
            </label>
          </div>
        </div>

        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save Changes</button>
        </div>
      </div>
    </section>

    <!-- Remote Management -->
    <section class="space-y-3" aria-labelledby="remote-heading">
      <h2 id="remote-heading" class="text-sm font-semibold text-text-primary">Remote Management</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-text-primary">Allow WAN Access to Admin Panel</p>
            <p class="text-xs text-text-secondary mt-0.5">Access the web interface from outside your network</p>
          </div>
          <button type="button" role="switch" aria-checked="false"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
          </button>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 pt-3 border-t border-border">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Remote Management Port</label>
            <input type="number" value="8443" min="1024" max="65535" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Allowed IP Ranges <span class="font-normal opacity-60">(leave blank for any)</span></label>
            <input type="text" placeholder="e.g. 1.2.3.4/32 or 5.6.7.0/24" class="<%= inp %>">
          </div>
        </div>
        <div class="flex items-start gap-2 rounded-lg border border-warning/30 bg-warning/5 px-3 py-2">
          <i class="fa-solid fa-triangle-exclamation text-warning text-xs mt-0.5 shrink-0" aria-hidden="true"></i>
          <p class="text-xs text-text-secondary">Exposing the admin panel to the WAN is a security risk. Use a VPN instead when possible.</p>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

    <!-- CLI Access (SSH / Telnet) -->
    <section class="space-y-3" aria-labelledby="cli-heading">
      <h2 id="cli-heading" class="text-sm font-semibold text-text-primary">CLI Access</h2>
      <div class="rounded-xl border border-border bg-surface-raised divide-y divide-border overflow-hidden">

        <div class="p-4 space-y-3">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-text-primary">SSH Access</p>
              <p class="text-xs text-text-secondary mt-0.5">Secure shell access for advanced configuration</p>
            </div>
            <button type="button" role="switch" aria-checked="false"
              class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
              <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
            </button>
          </div>
          <div class="grid sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-text-secondary mb-1.5">SSH Port</label>
              <input type="number" value="22" min="1024" max="65535" class="<%= inp %>">
            </div>
            <div>
              <label class="block text-xs font-medium text-text-secondary mb-1.5">Allowed from</label>
              <select class="<%= sel %>">
                <option value="LAN">LAN only</option>
                <option value="WAN">LAN + WAN</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Authorized Public Keys</label>
            <textarea rows="3" placeholder="Paste SSH public key(s), one per line" class="<%= inp %> resize-none font-mono text-xs"></textarea>
          </div>
        </div>

        <div class="p-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-text-primary">Telnet</p>
              <p class="text-xs text-warning flex items-center gap-1 mt-0.5">
                <i class="fa-solid fa-triangle-exclamation text-xs" aria-hidden="true"></i>
                Telnet is unencrypted — not recommended
              </p>
            </div>
            <button type="button" role="switch" aria-checked="false"
              class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
              <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
            </button>
          </div>
        </div>

      </div>
      <div class="flex justify-end">
        <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
      </div>
    </section>

    <!-- Dynamic DNS -->
    <section class="space-y-3" aria-labelledby="ddns-heading">
      <h2 id="ddns-heading" class="text-sm font-semibold text-text-primary">Dynamic DNS (DDNS)</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-text-primary">Enable DDNS</p>
            <p class="text-xs text-text-secondary mt-0.5">Automatically update a hostname when your IP address changes</p>
          </div>
          <button type="button" role="switch" aria-checked="false"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
          </button>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-3 border-t border-border">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Provider</label>
            <select class="<%= sel %>">
              <option value="">— Select provider —</option>
              <option value="noip">No-IP</option>
              <option value="dyndns">DynDNS</option>
              <option value="cloudflare">Cloudflare</option>
              <option value="duckdns">DuckDNS</option>
              <option value="custom">Custom (URL)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Hostname</label>
            <input type="text" placeholder="yourname.ddns.net" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Update Interval</label>
            <select class="<%= sel %>">
              <option value="5">Every 5 minutes</option>
              <option value="15" selected>Every 15 minutes</option>
              <option value="60">Every hour</option>
              <option value="360">Every 6 hours</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Username / Token</label>
            <input type="text" placeholder="API key or username" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Password</label>
            <input type="password" placeholder="••••••••" class="<%= inp %>">
          </div>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

    <!-- Scheduled Reboot -->
    <section class="space-y-3" aria-labelledby="scheduled-reboot-heading">
      <h2 id="scheduled-reboot-heading" class="text-sm font-semibold text-text-primary">Scheduled Reboot</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-text-primary">Enable Scheduled Reboot</p>
            <p class="text-xs text-text-secondary mt-0.5">Automatically restart the router at a set time</p>
          </div>
          <button type="button" role="switch" aria-checked="false"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
          </button>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 pt-3 border-t border-border">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Day(s)</label>
            <div class="flex flex-wrap gap-1.5">
              <% ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].forEach(function(d) { %>
              <button type="button"
                class="rounded-lg border px-2.5 py-1 text-xs font-medium transition-colors
                  <%= d === 'Sun' ? 'bg-primary text-primary-fg border-primary' : 'border-border text-text-secondary hover:bg-surface-overlay' %>">
                <%= d %>
              </button>
              <% }); %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Time</label>
            <input type="time" value="04:00" class="<%= inp %>">
          </div>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

    <!-- SNMP -->
    <section class="space-y-3" aria-labelledby="snmp-heading">
      <h2 id="snmp-heading" class="text-sm font-semibold text-text-primary">SNMP</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-text-primary">Enable SNMP</p>
            <p class="text-xs text-text-secondary mt-0.5">Allow network monitoring tools to poll device statistics</p>
          </div>
          <button type="button" role="switch" aria-checked="false"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
          </button>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-3 border-t border-border">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">SNMP Version</label>
            <select class="<%= sel %>">
              <option value="v2c">SNMPv2c</option>
              <option value="v3">SNMPv3</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Community String</label>
            <input type="text" value="public" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Port</label>
            <input type="number" value="161" min="1" max="65535" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">System Contact</label>
            <input type="text" placeholder="admin@example.com" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">System Location</label>
            <input type="text" placeholder="e.g. Server Room" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Trap Receiver IP</label>
            <input type="text" placeholder="Optional — e.g. 192.168.1.50" class="<%= inp %>">
          </div>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

    <!-- Syslog -->
    <section class="space-y-3" aria-labelledby="syslog-heading">
      <h2 id="syslog-heading" class="text-sm font-semibold text-text-primary">Syslog</h2>
      <div class="rounded-xl border border-border bg-surface-raised p-5 space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-text-primary">Remote Syslog</p>
            <p class="text-xs text-text-secondary mt-0.5">Forward system events to an external syslog server</p>
          </div>
          <button type="button" role="switch" aria-checked="false"
            class="relative inline-flex h-6 w-11 flex-shrink-0 items-center rounded-full bg-surface-sunken border border-border transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30">
            <span class="inline-block h-4 w-4 rounded-full bg-white shadow translate-x-1"></span>
          </button>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-3 border-t border-border">
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Server IP / Host</label>
            <input type="text" placeholder="192.168.1.50 or logs.example.com" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Port</label>
            <input type="number" value="514" class="<%= inp %>">
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Protocol</label>
            <select class="<%= sel %>">
              <option value="UDP">UDP</option>
              <option value="TCP">TCP</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text-secondary mb-1.5">Minimum Level</label>
            <select class="<%= sel %>">
              <option value="DEBUG">Debug</option>
              <option value="INFO">Info</option>
              <option value="WARNING" selected>Warning</option>
              <option value="ERROR">Error</option>
            </select>
          </div>
        </div>
        <div class="flex justify-end gap-2 pt-2 border-t border-border">
          <button type="button" class="rounded-lg border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-overlay transition-colors">Discard</button>
          <button type="button" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">Save</button>
        </div>
      </div>
    </section>

  </div>

<%- include('./_nav-close') %>
