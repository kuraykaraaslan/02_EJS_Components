<%
  var _company = locals.company || { name: 'Acme Corp', address: '123 Main Street · San Francisco, CA 94102' };
%>
<div class="bg-[#f4f5f7] px-8 py-6 rounded-b-2xl text-center space-y-2">
  <p class="text-xs text-text-secondary"><%= _company.name %> · <%= _company.address %></p>
  <div class="flex items-center justify-center gap-3 text-xs">
    <a href="#" class="text-text-secondary hover:text-primary transition-colors">Unsubscribe</a>
    <span class="text-border" aria-hidden="true">·</span>
    <a href="#" class="text-text-secondary hover:text-primary transition-colors">Privacy Policy</a>
    <span class="text-border" aria-hidden="true">·</span>
    <a href="#" class="text-text-secondary hover:text-primary transition-colors">Help Center</a>
  </div>
  <p class="text-xs text-text-secondary">© 2026 <%= _company.name %>. All rights reserved.</p>
</div>
