<%
  var success = locals.success || false;
%>

<% if (success) { %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md text-center space-y-5">
    <span class="flex h-16 w-16 mx-auto items-center justify-center rounded-full bg-success-subtle">
      <i class="fa-solid fa-check w-8 h-8 text-success text-3xl" aria-hidden="true"></i>
    </span>
    <div class="space-y-1">
      <h1 class="text-2xl font-bold text-text-primary">Password updated</h1>
      <p class="text-sm text-text-secondary">You can now sign in with your new password.</p>
    </div>
    <a href="/theme/common/auth/login"
      class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-fg hover:bg-primary-hover transition-colors">
      Go to login <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
    </a>
  </div>
</div>
<% } else { %>
<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md space-y-6">

    <div class="rounded-2xl border border-border bg-surface-raised shadow-sm p-8 space-y-6">

      <div class="text-center space-y-1">
        <div class="flex justify-center mb-3">
          <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary-subtle">
            <i class="fa-solid fa-lock w-6 h-6 text-primary text-xl" aria-hidden="true"></i>
          </span>
        </div>
        <h1 class="text-2xl font-bold text-text-primary">Set new password</h1>
        <p class="text-sm text-text-secondary">Choose a strong password for your account.</p>
      </div>

      <% if (locals.error) { %>
      <div role="alert" class="flex items-start gap-3 rounded-lg border p-3 bg-error-subtle border-error text-error-fg text-sm">
        <i class="fa-solid fa-circle-xmark mt-0.5 shrink-0" aria-hidden="true"></i>
        <span><%= locals.error %></span>
      </div>
      <% } %>

      <form action="/theme/common/auth/reset-password" method="post" novalidate class="space-y-4" id="reset-form">
        <div>
          <label for="new-password" class="block text-sm font-medium text-text-primary mb-1.5">New Password</label>
          <input type="password" id="new-password" name="newPassword" required autocomplete="new-password"
            class="block w-full rounded-md border border-border bg-surface text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary px-3 py-2 text-sm"
            placeholder="Minimum 8 characters">
          <p class="text-xs text-text-secondary mt-1" id="pw-error" style="display:none"></p>
        </div>
        <div>
          <label for="confirm-password" class="block text-sm font-medium text-text-primary mb-1.5">Confirm Password</label>
          <input type="password" id="confirm-password" name="confirmPassword" required autocomplete="new-password"
            class="block w-full rounded-md border border-border bg-surface text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary px-3 py-2 text-sm">
          <p class="text-xs text-text-secondary mt-1" id="confirm-error" style="display:none"></p>
        </div>
        <button type="submit"
          class="w-full inline-flex items-center justify-center gap-2 rounded-md font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus bg-primary text-primary-fg hover:bg-primary-hover px-4 py-2 text-sm">
          Reset Password
        </button>
      </form>

    </div>

    <p class="text-center text-sm text-text-secondary">
      Remembered it?
      <a href="/theme/common/auth/login" class="text-primary font-medium hover:underline">Back to login</a>
    </p>

  </div>
</div>

<script>
document.getElementById('reset-form').addEventListener('submit', function(e) {
  var pw  = document.getElementById('new-password').value;
  var cpw = document.getElementById('confirm-password').value;
  var pwErr  = document.getElementById('pw-error');
  var cpwErr = document.getElementById('confirm-error');
  var valid = true;
  pwErr.style.display = 'none'; cpwErr.style.display = 'none';
  if (!pw || pw.length < 8) {
    pwErr.textContent = 'Password must be at least 8 characters.';
    pwErr.style.display = 'block'; valid = false;
  }
  if (!cpw) {
    cpwErr.textContent = 'Please confirm your password.';
    cpwErr.style.display = 'block'; valid = false;
  } else if (pw !== cpw) {
    cpwErr.textContent = "Passwords don't match.";
    cpwErr.style.display = 'block'; valid = false;
  }
  if (!valid) e.preventDefault();
});
</script>
<% } %>
