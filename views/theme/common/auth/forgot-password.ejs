<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md space-y-6">

    <div class="rounded-2xl border border-border bg-surface-raised shadow-sm p-8 space-y-6">

      <!-- Header -->
      <div class="text-center space-y-1">
        <div class="flex justify-center mb-3">
          <span class="flex h-16 w-16 items-center justify-center rounded-2xl bg-warning-subtle text-3xl">🔒</span>
        </div>
        <h1 class="text-2xl font-bold text-text-primary">Forgot password?</h1>
        <p class="text-sm text-text-secondary leading-relaxed">
          Enter your email and we'll send you a link to reset your password.
        </p>
      </div>

      <%- include('../../../../modules/domain/common/auth/ForgotPasswordForm', {
        action: '/theme/common/auth/forgot-password',
        sent: locals.sent || false,
        email: locals.emailValue || ''
      }) %>

    </div>

    <div class="text-center space-y-2">
      <p class="text-sm text-text-secondary">
        Remember your password?
        <a href="/theme/common/auth/login" class="text-primary font-medium hover:underline">Back to login</a>
      </p>
      <p class="text-sm text-text-secondary">
        No account yet?
        <a href="/theme/common/auth/register" class="text-primary font-medium hover:underline">Sign up</a>
      </p>
    </div>

  </div>
</div>
