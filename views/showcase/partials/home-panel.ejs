<div class="max-w-4xl mx-auto py-10 px-2">

  <!-- Hero -->
  <div class="mb-10">
    <div class="flex items-center gap-3 mb-3">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-primary text-primary-fg text-lg font-bold shrink-0" aria-hidden="true">K</span>
      <div>
        <h1 class="text-2xl font-bold text-text-primary leading-tight"><%= site.name %></h1>
        <p class="text-sm text-text-secondary">Composable UI System for Real Products</p>
      </div>
    </div>
    <p class="text-sm text-text-secondary max-w-2xl leading-relaxed"><%= site.description %></p>
  </div>

  <!-- Quick start + scripts -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">

    <!-- Quick Start -->
    <div class="rounded-xl border border-border bg-surface-raised p-5">
      <h2 class="text-sm font-semibold text-text-primary mb-3 flex items-center gap-2">
        <i class="fa-solid fa-rocket text-primary" aria-hidden="true"></i>
        Quick Start
      </h2>
      <div class="space-y-2 text-xs font-mono">
        <div class="flex items-center gap-2 bg-surface-sunken rounded-lg px-3 py-2">
          <span class="text-text-disabled select-none">$</span>
          <span class="text-text-primary">npm install</span>
        </div>
        <div class="flex items-center gap-2 bg-surface-sunken rounded-lg px-3 py-2">
          <span class="text-text-disabled select-none">$</span>
          <span class="text-text-primary">npm run dev</span>
        </div>
      </div>
      <p class="text-xs text-text-secondary mt-3">Server starts at <span class="font-mono text-primary">http://localhost:3000</span></p>
    </div>

    <!-- Scripts -->
    <div class="rounded-xl border border-border bg-surface-raised p-5">
      <h2 class="text-sm font-semibold text-text-primary mb-3 flex items-center gap-2">
        <i class="fa-solid fa-terminal text-primary" aria-hidden="true"></i>
        Scripts
      </h2>
      <ul class="space-y-1.5 text-xs">
        <li class="flex items-start gap-2">
          <code class="font-mono bg-surface-sunken text-text-primary rounded px-1.5 py-0.5 shrink-0">npm run dev</code>
          <span class="text-text-secondary pt-0.5">server + CSS watcher in parallel</span>
        </li>
        <li class="flex items-start gap-2">
          <code class="font-mono bg-surface-sunken text-text-primary rounded px-1.5 py-0.5 shrink-0">npm run build</code>
          <span class="text-text-secondary pt-0.5">compile CSS then TypeScript → dist/</span>
        </li>
        <li class="flex items-start gap-2">
          <code class="font-mono bg-surface-sunken text-text-primary rounded px-1.5 py-0.5 shrink-0">npm start</code>
          <span class="text-text-secondary pt-0.5">run dist/server.js in production</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Tech stack -->
  <div class="rounded-xl border border-border bg-surface-raised p-5 mb-8">
    <h2 class="text-sm font-semibold text-text-primary mb-4 flex items-center gap-2">
      <i class="fa-solid fa-layer-group text-primary" aria-hidden="true"></i>
      Tech Stack
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% var stack = [
        { icon: 'fa-brands fa-node-js', label: 'Node.js', value: '20+' },
        { icon: 'fa-solid fa-server',   label: 'Express', value: '4' },
        { icon: 'fa-solid fa-file-code',label: 'EJS',     value: '3' },
        { icon: 'fa-brands fa-css3-alt',label: 'Tailwind', value: '4' },
        { icon: 'fa-brands fa-js',       label: 'TypeScript', value: '5' },
        { icon: 'fa-brands fa-font-awesome', label: 'Font Awesome', value: '6 Free' },
      ]; %>
      <% stack.forEach(function(s) { %>
        <div class="flex items-center gap-2.5 rounded-lg bg-surface-overlay px-3 py-2.5">
          <i class="<%= s.icon %> text-primary w-4 text-center" aria-hidden="true"></i>
          <div class="min-w-0">
            <p class="text-xs font-medium text-text-primary truncate"><%= s.label %></p>
            <p class="text-[10px] text-text-secondary"><%= s.value %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Layer architecture -->
  <div class="rounded-xl border border-border bg-surface-raised p-5 mb-8">
    <h2 class="text-sm font-semibold text-text-primary mb-4 flex items-center gap-2">
      <i class="fa-solid fa-diagram-project text-primary" aria-hidden="true"></i>
      Module Layers
    </h2>
    <div class="space-y-2">
      <% var layers = [
        { num: '1', label: 'modules/ui/',     desc: 'Primitive partials — atoms & molecules',         color: 'bg-info-subtle text-info' },
        { num: '2', label: 'modules/app/',    desc: 'Application-level patterns — organisms',          color: 'bg-primary-subtle text-primary' },
        { num: '3', label: 'modules/domain/', desc: 'Industry-specific components',                   color: 'bg-success-subtle text-success-fg' },
        { num: '4', label: 'views/themes/',   desc: 'Full-page multi-site demos',                     color: 'bg-warning-subtle text-warning-fg' },
      ]; %>
      <% layers.forEach(function(l) { %>
        <div class="flex items-center gap-3 rounded-lg px-3 py-2.5 bg-surface-overlay">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold shrink-0 <%= l.color %>"><%= l.num %></span>
          <code class="text-xs font-mono text-text-primary shrink-0"><%= l.label %></code>
          <span class="text-xs text-text-secondary truncate"><%= l.desc %></span>
        </div>
      <% }); %>
    </div>
    <p class="text-xs text-text-secondary mt-3">Each layer builds on the one above it. Keep business logic in domain/app layers; ui partials stay generic.</p>
  </div>

  <!-- Themes -->
  <div class="rounded-xl border border-border bg-surface-raised p-5 mb-8">
    <h2 class="text-sm font-semibold text-text-primary mb-4 flex items-center gap-2">
      <i class="fa-solid fa-palette text-primary" aria-hidden="true"></i>
      Live Themes
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <% var themes = [
        { label: 'Common Theme',    href: '/theme/common', desc: 'Shared layouts and account pages' },
        { label: 'Email Templates', href: '/theme/common/email', desc: 'Transactional email previews' },
        { label: 'Modem Theme',     href: '/theme/modem',  desc: 'Router/modem admin UI' },
      ]; %>
      <% themes.forEach(function(t) { %>
        <a
          href="<%= t.href %>"
          class="group flex flex-col gap-1 rounded-lg border border-border bg-surface-base hover:border-primary hover:bg-primary-subtle px-4 py-3 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus"
        >
          <span class="text-sm font-medium text-text-primary group-hover:text-primary transition-colors"><%= t.label %></span>
          <span class="text-xs text-text-secondary"><%= t.desc %></span>
          <span class="text-[10px] font-mono text-text-disabled mt-0.5"><%= t.href %></span>
        </a>
      <% }); %>
    </div>
  </div>

  <!-- Footer / author -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 pt-4 border-t border-border">
    <div class="text-xs text-text-secondary">
      Built by
      <a href="<%= site.authorUrl %>" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border-focus rounded"><%= site.author %></a>
      &middot; Licensed under 0BSD
    </div>
    <div class="flex items-center gap-3">
      <%- include('./github-button') %>
    </div>
  </div>

</div>
