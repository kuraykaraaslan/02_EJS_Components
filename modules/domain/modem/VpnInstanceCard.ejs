<%
  var _vpn  = locals.vpn  || {};
  var peers = (_vpn.wireguard && _vpn.wireguard.peers) ? _vpn.wireguard.peers : [];

  var statusMeta = {
    ACTIVE:     { ring: 'bg-success/10 border-success/30 text-success',               dot: 'bg-success',        label: 'Active'     },
    INACTIVE:   { ring: 'bg-surface-overlay border-border text-text-secondary',       dot: 'bg-text-secondary', label: 'Inactive'   },
    ERROR:      { ring: 'bg-error/10 border-error/30 text-error',                     dot: 'bg-error',          label: 'Error'      },
    CONNECTING: { ring: 'bg-warning/10 border-warning/30 text-warning',              dot: 'bg-warning',        label: 'Connecting' },
  };
  var sm = statusMeta[_vpn.status] || statusMeta.INACTIVE;

  function fmtBytes(b) {
    if (!b) return '0 B';
    if (b >= 1073741824) return (b / 1073741824).toFixed(1) + ' GB';
    if (b >= 1048576)    return (b / 1048576).toFixed(0) + ' MB';
    return (b / 1024).toFixed(0) + ' KB';
  }

  function fmtHandshake(iso) {
    if (!iso) return 'Never';
    try {
      var d = new Date(iso);
      var diffMs = Date.now() - d.getTime();
      var diffMin = Math.floor(diffMs / 60000);
      if (diffMin < 2)  return 'Just now';
      if (diffMin < 60) return diffMin + 'm ago';
      var diffH = Math.floor(diffMin / 60);
      if (diffH  < 24)  return diffH + 'h ago';
      return Math.floor(diffH / 24) + 'd ago';
    } catch(e) { return iso; }
  }
%>
<div class="rounded-xl border border-border bg-surface-raised overflow-hidden<%= locals.className ? ' ' + locals.className : '' %>">

  <!-- Header -->
  <div class="flex items-center gap-4 p-5">
    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl
      <%= _vpn.status === 'ACTIVE' ? 'bg-success/10 text-success' : 'bg-surface-overlay text-text-secondary' %>">
      <i class="fa-solid fa-lock text-sm" aria-hidden="true"></i>
    </span>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <p class="text-sm font-semibold text-text-primary"><%= _vpn.name %></p>
        <span class="text-xs font-mono bg-surface-overlay border border-border rounded px-1.5 py-0.5 text-text-secondary">
          <%= _vpn.type %>
        </span>
        <span class="text-xs bg-surface-overlay border border-border rounded px-1.5 py-0.5 text-text-secondary">
          <%= _vpn.role %>
        </span>
      </div>
      <p class="text-xs text-text-secondary mt-0.5">
        <% if (_vpn.role === 'SERVER') { %>
        <%= _vpn.clientCount %> client<%= _vpn.clientCount !== 1 ? 's' : '' %> connected
        <% } else if (_vpn.serverAddr) { %>
        Server: <span class="font-mono text-text-primary"><%= _vpn.serverAddr %></span>
        <% } %>
      </p>
    </div>
    <span class="inline-flex items-center gap-1.5 rounded-full border text-xs px-2.5 py-1 font-medium shrink-0 <%= sm.ring %>">
      <span class="h-1.5 w-1.5 rounded-full flex-shrink-0 <%= sm.dot %>
        <%= _vpn.status === 'CONNECTING' ? ' animate-pulse' : '' %>"></span>
      <%= sm.label %>
    </span>
  </div>

  <!-- WireGuard details -->
  <% if (_vpn.wireguard) { %>
  <div class="border-t border-border px-5 py-3 bg-surface-base">
    <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 text-xs">
      <div>
        <dt class="text-text-secondary">Listen Port</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.wireguard.listenPort %></dd>
      </div>
      <div>
        <dt class="text-text-secondary">Address</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.wireguard.address %></dd>
      </div>
      <div>
        <dt class="text-text-secondary">DNS</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.wireguard.dns || '—' %></dd>
      </div>
      <div class="col-span-2 sm:col-span-3">
        <dt class="text-text-secondary">Public Key</dt>
        <dd class="font-mono text-text-primary mt-0.5 break-all"><%= _vpn.wireguard.publicKey %></dd>
      </div>
    </dl>
  </div>

  <% if (peers.length > 0) { %>
  <div class="border-t border-border">
    <div class="px-5 py-2.5 bg-surface-raised">
      <p class="text-xs font-semibold text-text-primary">Peers (<%= peers.length %>)</p>
    </div>
    <table class="w-full text-xs">
      <thead>
        <tr class="bg-surface-base border-b border-border">
          <th class="text-left py-2 px-5 font-medium text-text-secondary">Name</th>
          <th class="text-left py-2 px-5 font-medium text-text-secondary hidden sm:table-cell">Last Handshake</th>
          <th class="text-left py-2 px-5 font-medium text-text-secondary hidden md:table-cell">Tx / Rx</th>
          <th class="text-left py-2 px-5 font-medium text-text-secondary">Allowed IPs</th>
        </tr>
      </thead>
      <tbody>
        <% peers.forEach(function(peer) { %>
        <tr class="border-t border-border hover:bg-surface-raised transition-colors">
          <td class="py-2.5 px-5">
            <p class="font-medium text-text-primary"><%= peer.name %></p>
            <p class="font-mono text-text-secondary truncate max-w-[120px]"><%= peer.publicKey %></p>
          </td>
          <td class="py-2.5 px-5 hidden sm:table-cell text-text-secondary">
            <%= fmtHandshake(peer.lastHandshake) %>
          </td>
          <td class="py-2.5 px-5 hidden md:table-cell text-text-secondary tabular-nums">
            <span class="text-info"><i class="fa-solid fa-arrow-up" aria-hidden="true"></i> <%= fmtBytes(peer.transferTx) %></span>
            <span class="mx-1" aria-hidden="true">·</span>
            <span class="text-success"><i class="fa-solid fa-arrow-down" aria-hidden="true"></i> <%= fmtBytes(peer.transferRx) %></span>
          </td>
          <td class="py-2.5 px-5 font-mono text-text-secondary">
            <%= (peer.allowedIps || []).join(', ') %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
  <% } %>

  <!-- OpenVPN details -->
  <% if (_vpn.openvpn) { %>
  <div class="border-t border-border px-5 py-3 bg-surface-base">
    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-2 text-xs">
      <div>
        <dt class="text-text-secondary">Port</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.openvpn.port %></dd>
      </div>
      <div>
        <dt class="text-text-secondary">Protocol</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.openvpn.protocol %></dd>
      </div>
      <div>
        <dt class="text-text-secondary">Cipher</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.openvpn.cipher %></dd>
      </div>
      <div>
        <dt class="text-text-secondary">Auth</dt>
        <dd class="font-mono font-medium text-text-primary mt-0.5"><%= _vpn.openvpn.auth %></dd>
      </div>
    </dl>
  </div>
  <% } %>

</div>
