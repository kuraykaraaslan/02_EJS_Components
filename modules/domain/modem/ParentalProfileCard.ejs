<%
  var _profile  = locals.profile  || {};
  var _devices  = locals.allDevices || [];   // ConnectedDevice[] for MAC→name resolution

  var blockedCats  = _profile.blockedCategories     || [];
  var customDomains = _profile.customBlockedDomains || [];
  var schedule     = _profile.schedule              || [];
  var macs         = _profile.devices               || [];

  var dayLabel = { MON:'Mon', TUE:'Tue', WED:'Wed', THU:'Thu', FRI:'Fri', SAT:'Sat', SUN:'Sun' };

  function resolveDevice(mac) {
    var d = _devices.find(function(dev) { return dev.mac === mac; });
    return d ? (d.customName || d.hostname) : mac;
  }

  var catIcon = {
    ADULT:           'fa-solid fa-ban',
    GAMBLING:        'fa-solid fa-dice',
    SOCIAL_MEDIA:    'fa-solid fa-hashtag',
    GAMING:          'fa-solid fa-gamepad',
    STREAMING_VIDEO: 'fa-solid fa-play',
    STREAMING_MUSIC: 'fa-solid fa-music',
    NEWS:            'fa-solid fa-newspaper',
    SHOPPING:        'fa-solid fa-bag-shopping',
    VIOLENCE:        'fa-solid fa-skull',
    DRUGS:           'fa-solid fa-pills',
  };

  var isEnabled = _profile.enabled !== false;
  var isPaused  = _profile.pauseNow;
%>
<div class="rounded-xl border border-border bg-surface-raised overflow-hidden<%= locals.className ? ' ' + locals.className : '' %>">

  <!-- Header -->
  <div class="flex items-center gap-4 p-5">
    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-warning/10 text-warning">
      <i class="fa-solid fa-shield-child" aria-hidden="true"></i>
    </span>
    <div class="flex-1 min-w-0">
      <p class="text-sm font-semibold text-text-primary"><%= _profile.name %></p>
      <p class="text-xs text-text-secondary mt-0.5">
        <%= macs.length %> device<%= macs.length !== 1 ? 's' : '' %>
        <% if (_profile.dailyLimitMinutes) { %>
        · <%= _profile.dailyLimitMinutes %> min/day
        <% } %>
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <% if (isPaused) { %>
      <span class="inline-flex items-center gap-1.5 rounded-full border bg-error/10 border-error/30 text-error text-xs px-2.5 py-1 font-medium">
        <i class="fa-solid fa-pause text-xs" aria-hidden="true"></i> Paused
      </span>
      <% } else if (!isEnabled) { %>
      <span class="inline-flex items-center gap-1.5 rounded-full border bg-surface-overlay border-border text-text-secondary text-xs px-2.5 py-1 font-medium">
        Off
      </span>
      <% } else { %>
      <span class="inline-flex items-center gap-1.5 rounded-full border bg-success/10 border-success/30 text-success text-xs px-2.5 py-1 font-medium">
        <span class="h-1.5 w-1.5 rounded-full bg-success shrink-0"></span> Active
      </span>
      <% } %>
    </div>
  </div>

  <!-- Devices -->
  <% if (macs.length > 0) { %>
  <div class="border-t border-border px-5 py-3 space-y-1.5">
    <p class="text-xs font-semibold text-text-primary mb-2">Devices</p>
    <div class="flex flex-wrap gap-1.5">
      <% macs.forEach(function(mac) { %>
      <span class="inline-flex items-center gap-1.5 rounded-lg bg-surface-overlay border border-border px-2.5 py-1 text-xs text-text-secondary">
        <i class="fa-solid fa-display text-xs text-text-secondary" aria-hidden="true"></i>
        <%= resolveDevice(mac) %>
      </span>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Blocked categories -->
  <% if (blockedCats.length > 0) { %>
  <div class="border-t border-border px-5 py-3 space-y-2">
    <p class="text-xs font-semibold text-text-primary">Blocked Categories</p>
    <div class="flex flex-wrap gap-1.5">
      <% blockedCats.forEach(function(cat) { %>
      <span class="inline-flex items-center gap-1.5 rounded-lg bg-error/10 border border-error/20 text-error text-xs px-2.5 py-1 font-medium">
        <i class="<%= catIcon[cat] || 'fa-solid fa-ban' %> text-xs" aria-hidden="true"></i>
        <%= cat.replace(/_/g, ' ') %>
      </span>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Custom blocked domains -->
  <% if (customDomains.length > 0) { %>
  <div class="border-t border-border px-5 py-3 space-y-2">
    <p class="text-xs font-semibold text-text-primary">Custom Blocked Domains</p>
    <div class="flex flex-wrap gap-1.5">
      <% customDomains.forEach(function(d) { %>
      <span class="font-mono text-xs bg-surface-overlay border border-border rounded px-2 py-0.5 text-text-secondary"><%= d %></span>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Schedule -->
  <% if (schedule.length > 0) { %>
  <div class="border-t border-border px-5 py-3 space-y-2">
    <p class="text-xs font-semibold text-text-primary">Active Schedule</p>
    <div class="space-y-1">
      <% schedule.forEach(function(s) { %>
      <div class="flex items-center gap-2 text-xs text-text-secondary">
        <span class="w-8 font-medium text-text-primary"><%= dayLabel[s.day] || s.day %></span>
        <span class="font-mono"><%= s.startTime %> – <%= s.endTime %></span>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

</div>
